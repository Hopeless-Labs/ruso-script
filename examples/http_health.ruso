name "HTTP GET health check"
description "Example HTTP probe: GET a JSON echo endpoint and match status and body"
impact "Demonstrates http/send/match/evidence for HTTP"
severity info
author "ruso-lab"

http health {
    method GET
    path "/get"
    timeout 5s
    follow_redirect false
    header "Accept" "application/json"
}

send health

match health.status == 200
match health.body contains "origin"
match health.body contains "url"

evidence health.body
